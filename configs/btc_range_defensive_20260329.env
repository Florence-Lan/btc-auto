# BTC range-defensive preset
# Window used for the regime call: 2026-01-29 to 2026-03-29 (BTCUSDT)
# Thesis: weak-bearish range, avoid mid-range entries, smaller size, faster profit lock.
# This file contains overrides only. Do not put API keys here.
# Keep DRY_RUN=true until the behavior is verified.

# Risk / exposure
LEVERAGE=12
MARGIN_USDT=45
DRY_RUN=true

# Regime and signal gating
REGIME_TREND_STRENGTH=0.00210
REGIME_RANGE_STRENGTH=0.00080
REGIME_BANDWIDTH_THRESHOLD=0.02700

SENTIMENT_FILTER_ENABLED=true
SENTIMENT_FILTER_MODE=all
SENTIMENT_PERIOD=15m
SENTIMENT_LONG_THRESHOLD=0.10
SENTIMENT_SHORT_THRESHOLD=0.10

FLOW_SCORE_THRESHOLD=0.12
LONG_FLOW_THRESHOLD=0.240
SHORT_FLOW_THRESHOLD=0.090

ORDERBOOK_FILTER_ENABLED=true
ORDERBOOK_FILTER_RANGE_ONLY=false
ORDERBOOK_LONG_THRESHOLD=0.03000
ORDERBOOK_SHORT_THRESHOLD=0.02000

# Stricter range entries
RANGE_RSI_LONG=34.00
RANGE_RSI_SHORT=66.00
RANGE_BAND_BUFFER=0.00100
RANGE_FLOW_FILTER=0.100

# Trend exits: smaller give-back, quicker realization
STOP_LOSS_PCT=0.01550
TP1_PCT=0.00650
TP2_PCT=0.01250
TP3_PCT=0.02000
TP1_CLOSE_RATIO=0.4000
TP2_CLOSE_RATIO=0.2500
MAX_HOLD_BARS=48
MIN_PROFIT_USDT=7.50
RUNNER_MODE=true
TRAILING_STOP_LOOSE_PCT=0.0220
TRAILING_STOP_PCT=0.0130
TRAILING_STOP_TIGHT_PCT=0.0105
TREND_REVERSAL_EXIT_ENABLED=true
TREND_REVERSAL_MIN_PROFIT_PCT=0.0030

# Range exits: improve R multiple and avoid stale holds
RANGE_STOP_LOSS_PCT=0.00580
RANGE_TAKE_PROFIT_PCT=0.00820
RANGE_MAX_HOLD_BARS=18

# High-volatility protection
VOL_GUARD_ENABLED=true
VOL_GUARD_ATR_PERIOD=12
VOL_GUARD_ATR_PCT_SOFT=0.00208
VOL_GUARD_ATR_PCT_HARD=0.00442
VOL_GUARD_SOFT_MULTIPLIER=0.609
VOL_GUARD_HARD_MULTIPLIER=0.367

# Entry patience: fewer trades, better locations
ENTRY_MODE=pullback_limit
ENTRY_CONFIRM_BARS=2
ENTRY_CONFIRM_EXTRA_MIXED=1
ENTRY_CONFIRM_EXTRA_RANGE=1
ENTRY_COOLDOWN_BARS=2
ENTRY_ATR_PERIOD=12
ENTRY_ATR_MULTIPLIER=1.450
ENTRY_ATR_MIN_PULLBACK_PCT=0.00120
ENTRY_ATR_MAX_PULLBACK_PCT=0.00450
ENTRY_PULLBACK_LONG_TREND_PCT=0.00120
ENTRY_PULLBACK_SHORT_TREND_PCT=0.00120
ENTRY_PULLBACK_LONG_RANGE_PCT=0.00320
ENTRY_PULLBACK_SHORT_RANGE_PCT=0.00150
ENTRY_MAX_WAIT_BARS=3
ENTRY_REFRESH_ON_SAME_SIGNAL=false
ENTRY_LIMIT_TIF=IOC
ENTRY_LIMIT_OFFSET_PCT=0.00058

# Smaller sizing across all regimes
REGIME_SIZE_TREND_MULTIPLIER=0.80
REGIME_SIZE_MIXED_MULTIPLIER=0.60
REGIME_SIZE_RANGE_MULTIPLIER=0.50

AUTO_POSITION_SIZING_ENABLED=true
AUTO_SIZE_MIN_MULTIPLIER=0.45
AUTO_SIZE_MAX_MULTIPLIER=1.00
AUTO_SIZE_SENSITIVITY=0.65
AUTO_SIZE_FLOW_REF=0.22
AUTO_SIZE_TREND_REF=0.0022
AUTO_SIZE_SPACE_REF=1.45
AUTO_SIZE_STOP_ADJUST_ENABLED=true
AUTO_SIZE_STOP_ADJUST_MIN=0.80
AUTO_SIZE_STOP_ADJUST_MAX=1.05
